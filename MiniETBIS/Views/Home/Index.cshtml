@{
    ViewData["Title"] = "MiniETBIS - Simulasyon Platformu";
}

<div class="text-center py-5 fade-in-up">
    <div class="mb-4">
        <span class="brand-icon d-inline-flex" style="width:64px; height:64px; font-size:1.5rem; border-radius:16px;">
            <i class="bi bi-building"></i>
        </span>
    </div>
    <h1 style="font-size:2.5rem; font-weight:800; letter-spacing:-1px; color:var(--text-primary)">MiniETBIS</h1>
    <p class="lead mt-2" style="color:var(--text-muted); max-width:500px; margin:0 auto">
        E-Ticaret Isletmeleri Bilgi Sistemi Simulasyon Platformu
    </p>
    <div class="mt-4 d-flex gap-3 justify-content-center flex-wrap">
        <a asp-controller="Account" asp-action="Register" class="btn btn-accent btn-lg px-4">
            <i class="bi bi-person-plus me-1"></i>Kayit Ol
        </a>
        <a asp-controller="Account" asp-action="Login" class="btn btn-ghost btn-lg px-4">
            <i class="bi bi-box-arrow-in-right me-1"></i>Giris Yap
        </a>
    </div>
</div>

<div class="row mt-5 g-4">
    <div class="col-md-4 stagger-1 fade-in-up">
        <div class="card h-100 text-center p-4">
            <div class="card-body">
                <div class="kpi-icon mx-auto kpi-indigo" style="width:52px; height:52px; font-size:1.3rem; border-radius:14px; color:#fff;">
                    <i class="bi bi-buildings"></i>
                </div>
                <h5 class="mt-3 fw-semibold">Firma Yonetimi</h5>
                <p class="small" style="color:var(--text-muted)">Firmanizi kaydedin, profilinizi guncel tutun.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 stagger-2 fade-in-up">
        <div class="card h-100 text-center p-4">
            <div class="card-body">
                <div class="kpi-icon mx-auto kpi-emerald" style="width:52px; height:52px; font-size:1.3rem; border-radius:14px; color:#fff;">
                    <i class="bi bi-box-seam"></i>
                </div>
                <h5 class="mt-3 fw-semibold">Urun &amp; Satis Girisi</h5>
                <p class="small" style="color:var(--text-muted)">Urunlerinizi ekleyin ve satis verilerinizi kaydedin.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 stagger-3 fade-in-up">
        <div class="card h-100 text-center p-4">
            <div class="card-body">
                <div class="kpi-icon mx-auto kpi-amber" style="width:52px; height:52px; font-size:1.3rem; border-radius:14px; color:#fff;">
                    <i class="bi bi-graph-up-arrow"></i>
                </div>
                <h5 class="mt-3 fw-semibold">Analitik Dashboard</h5>
                <p class="small" style="color:var(--text-muted)">Satis analizlerinizi grafiklerle takip edin.</p>
            </div>
        </div>
    </div>
</div>
