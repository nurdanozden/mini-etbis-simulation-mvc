@model MiniETBIS.Models.DTOs.DashboardDto
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="page-header d-flex align-items-center justify-content-between">
    <div>
        <h2><i class="bi bi-grid-1x2-fill text-accent me-2"></i>Admin Dashboard</h2>
        <p>Platformun genel gorunumu ve analizler</p>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-6 col-lg-3 kpi-card">
        <div class="card kpi-indigo">
            <div class="card-body text-center py-4">
                <div class="kpi-icon mx-auto"><i class="bi bi-buildings"></i></div>
                <div class="kpi-value">@Model.TotalCompanies</div>
                <div class="kpi-label">Toplam Firma</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3 kpi-card">
        <div class="card kpi-cyan">
            <div class="card-body text-center py-4">
                <div class="kpi-icon mx-auto"><i class="bi bi-box-seam"></i></div>
                <div class="kpi-value">@Model.TotalProducts</div>
                <div class="kpi-label">Toplam Urun</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3 kpi-card">
        <div class="card kpi-emerald">
            <div class="card-body text-center py-4">
                <div class="kpi-icon mx-auto"><i class="bi bi-cart-check"></i></div>
                <div class="kpi-value">@Model.TotalSales</div>
                <div class="kpi-label">Toplam Satis</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3 kpi-card">
        <div class="card kpi-amber">
            <div class="card-body text-center py-4">
                <div class="kpi-icon mx-auto"><i class="bi bi-cash-stack"></i></div>
                <div class="kpi-value">@Model.TotalRevenue.ToString("N0") &#8378;</div>
                <div class="kpi-label">Toplam Ciro</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 section-gap">
    <div class="col-lg-8 chart-card">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-graph-up"></i>Aylik Satis Trendi
            </div>
            <div class="card-body">
                <canvas id="monthlySalesChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4 chart-card">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-pie-chart"></i>Sektore Gore Firma
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <canvas id="sectorChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 section-gap">
    <div class="col-lg-6 chart-card">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-geo-alt"></i>Sehre Gore Satis
            </div>
            <div class="card-body">
                <canvas id="cityChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-6 chart-card">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-trophy"></i>En Cok Satan Urunler
            </div>
            <div class="card-body">
                <canvas id="topProductsChart"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        Chart.defaults.font.family = "'Inter', sans-serif";
        Chart.defaults.font.size = 12;
        Chart.defaults.color = '#64748b';
        Chart.defaults.plugins.legend.labels.usePointStyle = true;
        Chart.defaults.plugins.legend.labels.pointStyleWidth = 8;

        const baseOpts = {
            responsive: true,
            maintainAspectRatio: true,
            animation: { duration: 900, easing: 'easeOutQuart' },
            plugins: { legend: { labels: { font: { weight: 500 }, padding: 16 } } },
            scales: {
                x: { grid: { display: false }, ticks: { font: { size: 11 } } },
                y: { grid: { color: '#f1f5f9' }, ticks: { font: { size: 11 } }, border: { display: false } }
            }
        };

        // Aylik Satis
        new Chart(document.getElementById('monthlySalesChart'), {
            type: 'line',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlySales.Select(m => m.Month))),
                datasets: [{
                    label: 'Satis (?)',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlySales.Select(m => m.TotalAmount))),
                    borderColor: '#6366f1',
                    backgroundColor: 'rgba(99,102,241,0.06)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    pointHoverRadius: 7,
                    pointBackgroundColor: '#6366f1',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2,
                    borderWidth: 2.5
                }]
            },
            options: baseOpts
        });

        // Sektor
        new Chart(document.getElementById('sectorChart'), {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CompaniesBySector.Select(s => s.Sector))),
                datasets: [{
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CompaniesBySector.Select(s => s.CompanyCount))),
                    backgroundColor: ['#6366f1','#8b5cf6','#ec4899','#f97316','#eab308','#10b981','#06b6d4','#64748b','#ef4444','#14b8a6','#a855f7','#f43f5e'],
                    borderWidth: 0,
                    hoverOffset: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                animation: { duration: 900, easing: 'easeOutQuart' },
                cutout: '60%',
                plugins: { legend: { position: 'bottom', labels: { font: { size: 11, weight: 500 }, padding: 12, usePointStyle: true, pointStyleWidth: 8 } } }
            }
        });

        // Sehir
        new Chart(document.getElementById('cityChart'), {
            type: 'bar',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SalesByCity.Select(c => c.City))),
                datasets: [{
                    label: 'Satis (?)',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SalesByCity.Select(c => c.TotalAmount))),
                    backgroundColor: 'rgba(16,185,129,0.6)',
                    borderColor: '#10b981',
                    borderWidth: 0,
                    borderRadius: 6,
                    borderSkipped: false
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                indexAxis: 'y',
                animation: { duration: 900, easing: 'easeOutQuart' },
                plugins: { legend: { display: false } },
                scales: {
                    x: {
                        grid: { color: '#f1f5f9' },
                        ticks: { font: { size: 11 } },
                        border: { display: false }
                    },
                    y: {
                        grid: { display: false },
                        ticks: { font: { size: 11 } }
                    }
                }
            }
        });

        // Top urunler
        new Chart(document.getElementById('topProductsChart'), {
            type: 'bar',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopProducts.Select(p => p.ProductName))),
                datasets: [{
                    label: 'Adet',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopProducts.Select(p => p.TotalQuantity))),
                    backgroundColor: 'rgba(245,158,11,0.6)',
                    borderColor: '#f59e0b',
                    borderWidth: 0,
                    borderRadius: 6,
                    borderSkipped: false
                }]
            },
            options: { ...baseOpts, plugins: { ...baseOpts.plugins, legend: { display: false } } }
        });
    </script>
}
