@model MiniETBIS.Models.DTOs.AdminCreateCompanyDto
@{
    ViewData["Title"] = "Yeni Firma Ekle (Admin)";
}

<div class="row justify-content-center mt-3">
    <div class="col-md-8 col-lg-7">
        <div class="auth-card">
            <div class="card-header" style="background: linear-gradient(135deg, #0f172a, #1e293b) !important">
                <i class="bi bi-buildings fs-2 d-block mb-2"></i>
                <h4>Yeni Firma Ekle</h4>
                <span class="badge" style="background:var(--danger); font-size:0.7rem; margin-top:0.5rem; display:inline-block">Admin</span>
            </div>
            <div class="card-body">
                <form asp-action="AdminCreate" method="post">
                    <div asp-validation-summary="ModelOnly" class="toast-alert toast-error"></div>

                    <p class="small fw-semibold text-uppercase mb-3" style="color:var(--text-muted); letter-spacing:0.5px">
                        <i class="bi bi-buildings me-1"></i>Firma Bilgileri
                    </p>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Name" class="form-label">Firma Adi</label>
                            <input asp-for="Name" class="form-control" placeholder="Ornek: ABC Teknoloji A.S." />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="TaxNumber" class="form-label">Vergi Numarasi</label>
                            <input asp-for="TaxNumber" class="form-control" maxlength="11" placeholder="10-11 haneli" />
                            <span asp-validation-for="TaxNumber" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="City" class="form-label">Sehir</label>
                            <select asp-for="City" class="form-select">
                                <option value="">-- Sehir Secin --</option>
                                <option>Adana</option>
                                <option>Ankara</option>
                                <option>Antalya</option>
                                <option>Bursa</option>
                                <option>Denizli</option>
                                <option>Diyarbakir</option>
                                <option>Eskisehir</option>
                                <option>Gaziantep</option>
                                <option>Istanbul</option>
                                <option>Izmir</option>
                                <option>Kayseri</option>
                                <option>Kocaeli</option>
                                <option>Konya</option>
                                <option>Mersin</option>
                                <option>Mugla</option>
                                <option>Sakarya</option>
                                <option>Samsun</option>
                                <option>Trabzon</option>
                            </select>
                            <span asp-validation-for="City" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Sector" class="form-label">Sektor</label>
                            <select asp-for="Sector" class="form-select">
                                <option value="">-- Sektor Secin --</option>
                                <option>Elektronik</option>
                                <option>Giyim &amp; Moda</option>
                                <option>Gida &amp; Icecek</option>
                                <option>Kitap &amp; Kirtasiye</option>
                                <option>Spor &amp; Outdoor</option>
                                <option>Ev &amp; Dekorasyon</option>
                                <option>Kozmetik &amp; Bakim</option>
                                <option>Oyuncak &amp; Hobi</option>
                                <option>Otomotiv</option>
                                <option>Yazilim &amp; Teknoloji</option>
                                <option>Saglik &amp; Medikal</option>
                                <option>Diger</option>
                            </select>
                            <span asp-validation-for="Sector" class="text-danger small"></span>
                        </div>
                    </div>

                    <hr class="my-3" style="border-color:var(--border-subtle)">

                    <p class="small fw-semibold text-uppercase mb-3" style="color:var(--text-muted); letter-spacing:0.5px">
                        <i class="bi bi-person-badge me-1"></i>Firma Kullanici Hesabi
                    </p>
                    <p class="text-muted small mb-3">Bu bilgilerle firma sahibi sisteme giris yapabilecektir.</p>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Email" class="form-label">E-posta</label>
                            <input asp-for="Email" class="form-control" type="email" placeholder="firma@ornek.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Password" class="form-label">Sifre</label>
                            <input asp-for="Password" class="form-control" type="password" placeholder="En az 6 karakter" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-grid gap-2 mt-3">
                        <button type="submit" class="btn btn-accent btn-lg py-2">
                            <i class="bi bi-check-circle me-1"></i>Firma Olustur
                        </button>
                        <a asp-action="Index" class="btn btn-ghost">
                            <i class="bi bi-arrow-left me-1"></i>Listeye Don
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
