<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MiniETBIS</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                <span class="brand-icon"><i class="bi bi-building"></i></span>
                <span>MiniETBIS</span>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <i class="bi bi-list fs-4"></i>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto ms-3 gap-1">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Dashboard" asp-action="Index">
                                <i class="bi bi-grid-1x2-fill me-1"></i>Dashboard
                            </a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Company" asp-action="Index">
                                    <i class="bi bi-buildings me-1"></i>Firmalar
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Company" asp-action="AdminCreate">
                                    <i class="bi bi-plus-circle me-1"></i>Firma Ekle
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="AuditLog" asp-action="Index">
                                    <i class="bi bi-journal-text me-1"></i>Loglar
                                </a>
                            </li>
                        }
                        @if (User.IsInRole("Firma"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Company" asp-action="MyCompany">
                                    <i class="bi bi-building-check me-1"></i>Firmam
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Product" asp-action="Index">
                                    <i class="bi bi-box-seam me-1"></i>Urunler
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Sale" asp-action="Index">
                                    <i class="bi bi-receipt me-1"></i>Satislar
                                </a>
                            </li>
                        }
                    }
                </ul>
                <ul class="navbar-nav gap-2 align-items-center">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <span class="nav-link user-badge">
                                <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                            </span>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="btn btn-sm btn-ghost">
                                    <i class="bi bi-box-arrow-right me-1"></i>Cikis
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-sm btn-ghost" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Giris
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-sm btn-accent" asp-controller="Account" asp-action="Register">
                                Kayit Ol
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        @if (TempData["Success"] != null)
        {
            <div class="toast-alert toast-success fade-in-up">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close btn-close-sm ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="toast-alert toast-error fade-in-up">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close btn-close-sm ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container d-flex justify-content-between align-items-center">
            <span>&copy; 2026 MiniETBIS</span>
            <span class="text-muted small">E-Ticaret Bilgi Sistemi Simulasyon Platformu</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
