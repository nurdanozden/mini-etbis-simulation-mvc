@model MiniETBIS.Models.DTOs.EditProductDto
@{
    ViewData["Title"] = "Urun Duzenle";
}

<div class="row justify-content-center mt-3">
    <div class="col-md-6 col-lg-5">
        <div class="auth-card">
            <div class="card-header" style="background:var(--warning)!important">
                <i class="bi bi-pencil-square fs-2 d-block mb-2"></i>
                <h4>Urun Duzenle</h4>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="toast-alert toast-error"></div>
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Urun Adi</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Category" class="form-label">Kategori</label>
                        <input asp-for="Category" class="form-control" />
                        <span asp-validation-for="Category" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Price" class="form-label">Fiyat (&#8378;)</label>
                        <input asp-for="Price" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-warning w-100 py-2">
                        <i class="bi bi-check-lg me-1"></i>Guncelle
                    </button>
                    <a asp-action="Index" class="btn btn-ghost w-100 mt-2">Iptal</a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
