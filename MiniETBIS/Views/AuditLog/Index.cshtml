@model IEnumerable<MiniETBIS.Models.AuditLog>
@{
    ViewData["Title"] = "Sistem Loglari";
}

<div class="page-header">
    <h2><i class="bi bi-journal-text text-accent me-2"></i>Sistem Loglari</h2>
    <p>Kullanici islem gecmisi</p>
</div>

<div class="modern-table">
    <table class="table mb-0">
        <thead>
            <tr>
                <th>Kullanici</th>
                <th>Islem</th>
                <th>Tarih</th>
                <th>IP Adresi</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model)
            {
                <tr>
                    <td><code style="font-size:0.8rem; color:var(--accent)">@log.UserId[..8]...</code></td>
                    <td>@log.Action</td>
                    <td class="text-muted" style="font-size:0.8rem">@log.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</td>
                    <td class="text-muted">@(log.IPAddress ?? "-")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="d-flex justify-content-center gap-2 mt-4">
    @if (ViewBag.Page > 1)
    {
        <a asp-action="Index" asp-route-page="@(ViewBag.Page - 1)" class="btn btn-ghost">
            <i class="bi bi-chevron-left me-1"></i>Onceki
        </a>
    }
    <a asp-action="Index" asp-route-page="@(ViewBag.Page + 1)" class="btn btn-ghost">
        Sonraki<i class="bi bi-chevron-right ms-1"></i>
    </a>
</div>
